generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  email String @unique
  password String
  username String
  picturePath String
  game Game[]
}

model Game {
  id String @id @default(uuid())
  code String @unique
  name String
  category String
  description String
  available Boolean @db.Boolean
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}