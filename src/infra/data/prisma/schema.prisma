generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  username String
  email String @unique
  password String
  game Game[]
}

model Game {
  id String @id @default(uuid())
  name String
  category String
  description String
  available Boolean @db.Boolean
  iduser User @relation(fields: [id], references: [id], onDelete: Cascade)
}